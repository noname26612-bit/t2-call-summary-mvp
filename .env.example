PORT=3000
LOG_LEVEL=info
APP_TIMEZONE=Europe/Moscow
AUTO_RUN_MIGRATIONS=false
IGNORE_LIST_BOOTSTRAP_FROM_ENV=true
SHUTDOWN_TIMEOUT_MS=10000

# PostgreSQL connection (choose one mode)
# Production baseline (`2026-03-23`): self-hosted PostgreSQL on same VM/network.
# For container runtime use internal host/service name (example: `t2-postgres`).
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=ats_call_summary
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_CONNECT_TIMEOUT_MS=5000
DB_APPLICATION_NAME=ats-call-summary

IGNORED_PHONES=+79161245991,+79779564221,+79250839552,+79853087357,+79104040283,+79263591125,+79104650471,+79161730328,+79772606209,+79253464677,+79036636511,+79913139383,+79017225571,+79278009561,+79692165080,+79774448536,+79017431255

# Main app -> ai-gateway integration
# Local dev example only:
# AI_GATEWAY_URL uses localhost when main app and gateway are run from the same machine.
# For production/container-to-container routing, use a real reachable internal address
# (service name, container address, or internal host), not blind localhost.
AI_GATEWAY_URL=http://localhost:3001
AI_GATEWAY_SHARED_SECRET=replace_with_same_secret_as_gateway
AI_GATEWAY_TIMEOUT_MS=20000
# Skip analyze when transcript signal is too low to justify AI cost.
# Safe default is intentionally moderate to avoid dropping normal short calls.
AI_ANALYZE_MIN_TRANSCRIPT_CHARS=16

# Optional ingress auth for POST /api/process-call.
# If empty, auth is disabled.
# Safety rule: if TELE2_INGEST_ENABLED=true, this must be non-empty
# (otherwise /api/ingest/tele2 returns TELE2_INGEST_MISCONFIGURED).
INGEST_SHARED_SECRET=

# Tele2 ingest adapter switch (safe default).
# false: /api/ingest/tele2 returns TELE2_INGEST_DISABLED
# true: /api/ingest/tele2 is enabled
TELE2_INGEST_ENABLED=false

# Optional Tele2 payload field paths (dot notation).
# Leave empty until Tele2 payload contract is confirmed.
# Fallback (when empty): top-level canonical keys phone/callDateTime/transcript.
TELE2_PHONE_FIELD_PATH=
TELE2_CALL_DATETIME_FIELD_PATH=
TELE2_TRANSCRIPT_FIELD_PATH=
TELE2_CALL_TYPE_FIELD_PATH=
TELE2_CALLER_NUMBER_FIELD_PATH=
TELE2_CALLEE_NUMBER_FIELD_PATH=
TELE2_DESTINATION_NUMBER_FIELD_PATH=
TELE2_DURATION_SEC_FIELD_PATH=
TELE2_ANSWERED_FIELD_PATH=
TELE2_NO_ANSWER_FIELD_PATH=
# Optional stable call identifier path for idempotency guard
# (fallback auto-detect checks: callId, externalCallId, recordFileName, recordingId).
TELE2_CALL_ID_FIELD_PATH=

# Telegram delivery
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
# Optional: additional global recipients (numeric chat_id only, comma-separated)
# Example: TELEGRAM_GLOBAL_CHAT_IDS=-1001111111111,123456789
TELEGRAM_GLOBAL_CHAT_IDS=
# Optional: conditional routing by employee/subscriber number (normalized with project phone normalizer)
# JSON object: {"<phone>":["<chat_id_1>","<chat_id_2>"]}
# Example for Milena route:
# TELEGRAM_NUMBER_ROUTE_RULES={"+79779564221":["<MILENA_CHAT_ID>"]}
TELEGRAM_NUMBER_ROUTE_RULES=
TELEGRAM_API_TIMEOUT_MS=10000
# Optional secret for Telegram webhook header (fallback path):
# X-Telegram-Bot-Api-Secret-Token
TELEGRAM_WEBHOOK_SECRET=
# Callback updates polling (primary production path; no public HTTPS webhook required)
TELEGRAM_UPDATES_POLLING_ENABLED=true
TELEGRAM_UPDATES_POLL_TIMEOUT_SEC=8
TELEGRAM_UPDATES_POLL_IDLE_DELAY_MS=400
TELEGRAM_UPDATES_POLL_ERROR_DELAY_MS=3000
TELEGRAM_UPDATES_POLL_MAX_BATCH_SIZE=25
TELEGRAM_UPDATES_OFFSET_KEY=transcript_callback
TELEGRAM_UPDATES_CLEAR_WEBHOOK_ON_START=true
TELEGRAM_UPDATES_SKIP_BACKLOG_ON_FIRST_START=false

# Tele2 polling auth settings.
# For `scripts/run-tele2-poll-once.sh` both vars below are required.
# Wrapper exits early with explicit auth-env error if they are missing.
T2_API_BASE_URL=https://ats2.t2.ru/crm/openapi
# WARNING (Tele2 ATS API keys):
# regenerating tokens invalidates the previous access/refresh pair immediately.
# Do not regenerate "in advance". Rotate only as a controlled step:
# update env -> restart service -> verify right away.
T2_API_TOKEN=replace_with_live_t2_access_token
T2_REFRESH_TOKEN=replace_with_live_t2_refresh_token
T2_AUTH_SCHEME=plain
# Refresh helper auth scheme (plain|bearer). Keep aligned with Tele2 contract.
T2_REFRESH_AUTH_SCHEME=plain
# Optional explicit refresh endpoint override
# T2_REFRESH_URL=https://ats2.t2.ru/crm/openapi/authorization/refresh/token
T2_API_TIMEOUT_MS=10000
T2_TIMEZONE_OFFSET=+03:00

# Manual one-shot Tele2 polling
# (also reused by the VM wrapper/timer as safe starter defaults)
TELE2_POLL_LOOKBACK_MINUTES=60
TELE2_POLL_FETCH_LIMIT=30
TELE2_POLL_MAX_CANDIDATES=10
TELE2_POLL_MIN_AUDIO_BYTES=4096
TELE2_POLL_DOWNLOAD_RETRY_ATTEMPTS=3
TELE2_POLL_DOWNLOAD_RETRY_BACKOFF_MS=1500
TELE2_POLL_TRANSCRIBE_RETRY_ATTEMPTS=2
TELE2_POLL_TRANSCRIBE_RETRY_BACKOFF_MS=1500
# Optional: allow replay of skipped records by last_error_code (comma-separated),
# e.g. POLZA_EMPTY_TRANSCRIPTION,AI_GATEWAY_EMPTY_TRANSCRIPT
TELE2_POLL_RETRY_SKIPPED_ERROR_CODES=
# Tele2 info page size used in explicit replay mode (--record-file-name)
TELE2_POLL_REPLAY_FETCH_LIMIT=500
# Hard rule in poller runtime: analyze only calls with conversation duration > 10 sec,
# unanswered/missed and short calls are skipped before transcription.
TELE2_POLL_DRY_RUN=false
TELE2_POLL_RETRY_FAILED=true
# Token refresh lifecycle for scheduled wrapper flow
TELE2_POLL_TOKEN_REFRESH_ENABLED=true
TELE2_POLL_TOKEN_REFRESH_ON_403=true
TELE2_POLL_TOKEN_REFRESH_LEEWAY_SECONDS=900
# Used by scripts/run-tele2-poll-once.sh (systemd wrapper).
# Direct `npm run tele2:poll-once` uses `--timeout-ms` or `T2_API_TIMEOUT_MS`.
TELE2_POLL_TIMEOUT_MS=180000

# Optional explicit URLs for helper/poll scripts
PROCESS_CALL_URL=http://127.0.0.1:3000/api/process-call
AI_GATEWAY_TRANSCRIBE_PATH=/transcribe

# Reference for ai-gateway canonical provider env (set in ai-gateway/.env)
# POLZA_API_KEY=replace_me
# POLZA_BASE_URL=https://polza.ai/api/v1
# POLZA_MODEL=openai/gpt-5-mini
# POLZA_TRANSCRIPTION_MODEL=openai/gpt-4o-mini-transcribe
# legacy alias still supported:
# POLZA_TRANSCRIBE_MODEL=openai/gpt-4o-mini-transcribe
# ALLOW_REQUEST_MODEL_OVERRIDES=false
# POLZA_TIMEOUT_MS=20000
# POLZA_MAX_RETRIES=0
# Fallback-only analyze pricing (RUB per 1K tokens), used when provider cost is absent.
# Source snapshot: Polza model endpoint (`/models/openai/gpt-5-mini`) as of 2026-03-23.
# POLZA_ANALYZE_INPUT_RUB_PER_1K_TOKENS=0.023963125
# POLZA_ANALYZE_OUTPUT_RUB_PER_1K_TOKENS=0.191705
