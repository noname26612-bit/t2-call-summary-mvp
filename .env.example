PORT=3000
LOG_LEVEL=info
APP_TIMEZONE=Europe/Moscow
AUTO_RUN_MIGRATIONS=false
IGNORE_LIST_BOOTSTRAP_FROM_ENV=true
SHUTDOWN_TIMEOUT_MS=10000

# PostgreSQL connection (choose one mode)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=ats_call_summary
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_CONNECT_TIMEOUT_MS=5000
DB_APPLICATION_NAME=ats-call-summary

IGNORED_PHONES=+79990000001,+79990000002

# Main app -> ai-gateway integration
# Local dev example only:
# AI_GATEWAY_URL uses localhost when main app and gateway are run from the same machine.
# For production/container-to-container routing, use a real reachable internal address
# (service name, container address, or internal host), not blind localhost.
AI_GATEWAY_URL=http://localhost:3001
AI_GATEWAY_SHARED_SECRET=replace_with_same_secret_as_gateway
AI_GATEWAY_TIMEOUT_MS=20000

# Optional ingress auth for POST /api/process-call.
# If empty, auth is disabled.
# Safety rule: if TELE2_INGEST_ENABLED=true, this must be non-empty
# (otherwise /api/ingest/tele2 returns TELE2_INGEST_MISCONFIGURED).
INGEST_SHARED_SECRET=

# Tele2 ingest adapter switch (safe default).
# false: /api/ingest/tele2 returns TELE2_INGEST_DISABLED
# true: /api/ingest/tele2 is enabled
TELE2_INGEST_ENABLED=false

# Optional Tele2 payload field paths (dot notation).
# Leave empty until Tele2 payload contract is confirmed.
# Fallback (when empty): top-level canonical keys phone/callDateTime/transcript.
TELE2_PHONE_FIELD_PATH=
TELE2_CALL_DATETIME_FIELD_PATH=
TELE2_TRANSCRIPT_FIELD_PATH=

# Telegram delivery
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
TELEGRAM_API_TIMEOUT_MS=10000

# Optional t2 settings
T2_API_BASE_URL=https://ats2.t2.ru/crm/openapi
T2_API_TOKEN=your_t2_api_token_here
T2_REFRESH_TOKEN=
T2_AUTH_SCHEME=plain
# Refresh helper auth scheme (plain|bearer). Keep aligned with Tele2 contract.
T2_REFRESH_AUTH_SCHEME=plain
# Optional explicit refresh endpoint override
# T2_REFRESH_URL=https://ats2.t2.ru/crm/openapi/authorization/refresh/token
T2_API_TIMEOUT_MS=10000
T2_TIMEZONE_OFFSET=+03:00

# Manual one-shot Tele2 polling
# (also reused by the VM wrapper/timer as safe starter defaults)
TELE2_POLL_LOOKBACK_MINUTES=60
TELE2_POLL_FETCH_LIMIT=30
TELE2_POLL_MAX_CANDIDATES=10
TELE2_POLL_MIN_AUDIO_BYTES=4096
TELE2_POLL_DRY_RUN=false
TELE2_POLL_RETRY_FAILED=true
# Token refresh lifecycle for scheduled wrapper flow
TELE2_POLL_TOKEN_REFRESH_ENABLED=true
TELE2_POLL_TOKEN_REFRESH_ON_403=true
TELE2_POLL_TOKEN_REFRESH_LEEWAY_SECONDS=900
# Used by scripts/run-tele2-poll-once.sh (systemd wrapper).
# Direct `npm run tele2:poll-once` uses `--timeout-ms` or `T2_API_TIMEOUT_MS`.
TELE2_POLL_TIMEOUT_MS=180000

# Optional explicit URLs for helper/poll scripts
PROCESS_CALL_URL=http://127.0.0.1:3000/api/process-call
AI_GATEWAY_TRANSCRIBE_PATH=/transcribe

# Reference for ai-gateway canonical provider env (set in ai-gateway/.env)
# POLZA_API_KEY=replace_me
# POLZA_BASE_URL=https://polza.ai/api/v1
# POLZA_MODEL=replace_me
# POLZA_TIMEOUT_MS=20000
