PORT=3000
LOG_LEVEL=info
APP_TIMEZONE=Europe/Moscow
AUTO_RUN_MIGRATIONS=false
IGNORE_LIST_BOOTSTRAP_FROM_ENV=true
SHUTDOWN_TIMEOUT_MS=10000

# PostgreSQL connection (choose one mode)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=ats_call_summary
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_CONNECT_TIMEOUT_MS=5000
DB_APPLICATION_NAME=ats-call-summary

IGNORED_PHONES=+79990000001,+79990000002
AI_GATEWAY_URL=http://localhost:8080
AI_GATEWAY_SHARED_SECRET=replace_with_same_secret_as_gateway
AI_GATEWAY_TIMEOUT_MS=20000

# OpenAI is called by external ai-gateway after cutover.
# OPENAI_API_KEY is not used by main app runtime path.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
TELEGRAM_API_TIMEOUT_MS=10000
T2_API_BASE_URL=https://example.t2.api
T2_API_TOKEN=your_t2_api_token_here
T2_API_TIMEOUT_MS=10000
