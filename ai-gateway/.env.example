NODE_ENV=development
PORT=3001
LOG_LEVEL=info
BODY_LIMIT=1mb
TRANSCRIBE_FILE_MAX_BYTES=20971520
SHUTDOWN_TIMEOUT_MS=10000

# Canonical shared secret name
AI_GATEWAY_SHARED_SECRET=replace_with_strong_shared_secret

# Canonical Polza provider settings
POLZA_API_KEY=replace_me
POLZA_BASE_URL=https://polza.ai/api/v1
POLZA_MODEL=openai/gpt-5-mini
# Default STT model for runtime transcription.
POLZA_TRANSCRIBE_MODEL=openai/gpt-4o-transcribe
# Optional cheaper candidate for opt-in compare experiments
POLZA_TRANSCRIBE_MODEL_CANDIDATE=openai/whisper-1
POLZA_TIMEOUT_MS=20000
# Explicit retry policy for OpenAI SDK (0 disables hidden automatic retries).
POLZA_MAX_RETRIES=0
# Analyze pricing fallback for `estimated_cost_rub` (RUB per 1K tokens).
# Runtime first uses provider usage fields (`usage.cost_rub` / `usage.cost`) when present.
# These values are fallback-only and were pulled from Polza model endpoint
# `GET /api/v1/models/openai/gpt-5-mini` on 2026-03-23.
POLZA_ANALYZE_INPUT_RUB_PER_1K_TOKENS=0.023963125
POLZA_ANALYZE_OUTPUT_RUB_PER_1K_TOKENS=0.191705
