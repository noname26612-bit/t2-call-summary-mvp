NODE_ENV=development
PORT=3001
LOG_LEVEL=info
BODY_LIMIT=1mb
SHUTDOWN_TIMEOUT_MS=10000

# Canonical shared secret name
AI_GATEWAY_SHARED_SECRET=replace_with_strong_shared_secret

# Canonical Polza provider settings
POLZA_API_KEY=replace_me
POLZA_BASE_URL=https://polza.ai/api/v1
POLZA_MODEL=replace_me
POLZA_TIMEOUT_MS=20000

# Temporary fallback names for smooth cutover (remove after migration)
# GATEWAY_SHARED_SECRET=replace_with_strong_shared_secret
# OPENAI_API_KEY=replace_with_current_provider_api_key_if_needed
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_TIMEOUT_MS=20000
