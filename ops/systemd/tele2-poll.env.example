# Optional env overrides for t2-tele2-poll.service.
# Copy to /opt/t2-call-summary/tele2-poll.env on VM and fill required values.
# Do not overwrite an already configured live file; edit it in place via sudoedit.
# WARNING (Tele2 ATS API keys): token regeneration invalidates previous tokens.
# Never regenerate "for prep". Do it only when you can immediately:
# 1) update this env file, 2) restart service, 3) run verification.

# Required for Tele2 API access.
T2_API_TOKEN=replace_with_live_tele2_access_token
T2_REFRESH_TOKEN=replace_with_live_tele2_refresh_token

# Default auth format for Tele2 OpenAPI in this project.
T2_AUTH_SCHEME=plain
# Keep refresh auth aligned with current Tele2 auth format.
T2_REFRESH_AUTH_SCHEME=plain
# If omitted, wrapper/helper use:
#   ${T2_API_BASE_URL}/authorization/refresh/token
# (or default base https://ats2.t2.ru/crm/openapi)
# T2_REFRESH_URL=

# Safe starter profile for scheduled poll-once runs.
TELE2_POLL_LOOKBACK_MINUTES=60
TELE2_POLL_FETCH_LIMIT=30
TELE2_POLL_MAX_CANDIDATES=10
TELE2_POLL_MIN_AUDIO_BYTES=4096
TELE2_POLL_TIMEOUT_MS=180000
# true = dry-run only (no /api/process-call writes), false = live
TELE2_POLL_DRY_RUN=false
TELE2_POLL_RETRY_FAILED=true
TELE2_POLL_TOKEN_REFRESH_ENABLED=true
TELE2_POLL_TOKEN_REFRESH_ON_403=true
# Preflight refresh threshold (seconds before access token exp).
TELE2_POLL_TOKEN_REFRESH_LEEWAY_SECONDS=900

# Keep production container-to-container routing unchanged.
AI_GATEWAY_URL=http://ai-gateway:3001
PROCESS_CALL_URL=http://t2-call-summary:3000/api/process-call
AI_GATEWAY_TRANSCRIBE_PATH=/transcribe

# Optional wrapper paths (usually no change needed).
PROJECT_DIR=/home/artem266/t2-call-summary-mvp
TELE2_POLL_MAIN_ENV_FILE=/opt/t2-call-summary/main.env
TELE2_POLL_ENV_FILE=/opt/t2-call-summary/tele2-poll.env
TELE2_POLL_DOCKER_NETWORK=t2-app-net
TELE2_POLL_NODE_IMAGE=node:20-alpine
TELE2_POLL_LOCK_FILE=/tmp/t2-tele2-poll.lock
TELE2_POLL_LOG_FILE=/home/artem266/t2-call-summary-mvp/logs/tele2-poll-once.log
